    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.113.0"
  },
  "overrides": {
    "sharp": "$sharp"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
