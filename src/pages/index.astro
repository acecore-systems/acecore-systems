---
import BaseLayout from "../layouts/BaseLayout.astro";
import home from "../data/home.json";
import site from "../data/site.json";

const routeSteps = [
  {
    number: "01",
    title: "現状整理",
    body: "課題を可視化し、優先順位を決める",
  },
  {
    number: "02",
    title: "業務フロー",
    body: "流れと役割を整理し、あるべき姿を描く",
  },
  {
    number: "03",
    title: "管理画面",
    body: "必要な機能を使いやすく構成する",
  },
  {
    number: "04",
    title: "データ連携",
    body: "社内外のデータをつなぎ、整える",
  },
  {
    number: "05",
    title: "Web・サイト機能",
    body: "CMS、検索、フォーム、AIチャットなどを組み込む",
  },
  {
    number: "06",
    title: "運用改善",
    body: "公開後も継続的に改善し続ける",
  },
];

const lanes = [
  {
    name: "業務ルート",
    description: "仕事の流れを整える",
    tone: "teal",
    icon: "/assets/route-icon-business.png",
    cells: [
      "業務整理・要件定義",
      "業務設計・最適化",
      "権限・ルール設計",
      "運用フロー定着",
    ],
  },
  {
    name: "データルート",
    description: "データをつなぎ、活かす",
    tone: "teal",
    icon: "/assets/route-icon-data.png",
    cells: [
      "データ設計",
      "API・外部連携",
      "インポート・移行",
      "データ活用・分析",
    ],
  },
  {
    name: "Webルート",
    description: "Webで価値を届ける",
    tone: "gold",
    icon: "/assets/route-icon-web.png",
    cells: [
      "Webアプリ開発",
      "管理画面・ダッシュボード",
      "CMS・検索・フォーム・AIチャット",
      "セキュリティ・パフォーマンス改善",
    ],
  },
  {
    name: "運用ルート",
    description: "安心して使い続ける",
    tone: "gray",
    icon: "/assets/route-icon-ops.png",
    cells: [
      "保守・監視",
      "改善提案・追加開発",
      "運用サポート",
      "継続的な最適化",
    ],
  },
];

const plannerGroups = [
  {
    label: "現場業務",
    options: [
      {
        area: "business",
        label: "紙やExcelでの管理が多く、ミスや抜け漏れがある",
      },
      {
        area: "business",
        label: "申請・承認・確認の流れが部門ごとに分かれている",
      },
      { area: "ops", label: "担当者依存で、引き継ぎや確認に時間がかかる" },
    ],
  },
  {
    label: "画面・サイト",
    options: [
      { area: "admin", label: "社内向けの管理画面や会員機能を作りたい" },
      {
        area: "site",
        label: "問い合わせ、検索、CMS、AIチャットをサイトに足したい",
      },
      {
        area: "site",
        label: "フォームから相談内容や種別を整理して受け取りたい",
      },
    ],
  },
  {
    label: "データ・連携",
    options: [
      {
        area: "data",
        label: "外部サービス、API、スプレッドシートをつなぎたい",
      },
      { area: "data", label: "二重入力や手作業の転記を減らしたい" },
      { area: "ops", label: "運用後の改善、保守、監視まで見通したい" },
    ],
  },
];

const plannerTabs = ["現場業務", "データ・連携", "Web・サイト", "運用・改善"];
const plannerOptions = plannerGroups.flatMap((group) => group.options);

const pricingRows = [
  {
    label: "小さく始めるプラン",
    note: "課題整理〜最小構成のシステム開発",
    period: "1〜2ヶ月",
    price: "30〜80万円",
  },
  {
    label: "標準プラン",
    note: "業務・データ・Webを含む運用基盤を構築",
    period: "2〜4ヶ月",
    price: "80〜250万円",
  },
  {
    label: "拡張プラン",
    note: "複数システム連携・高度なカスタマイズ",
    period: "4ヶ月〜",
    price: "250万円〜",
  },
  {
    label: "運用サポート",
    note: "保守・改善・追加開発の継続サポート",
    period: "継続",
    price: "月額2〜10万円〜",
  },
];

const developmentSteps = [
  {
    number: "01",
    title: "現状整理・要件定義",
    body: "課題を整理し、やるべきことを明確にします。",
  },
  {
    number: "03",
    title: "設計・プロトタイプ",
    body: "業務・データ・画面の設計を行います。",
  },
  {
    number: "03",
    title: "開発・テスト",
    body: "小さく作って確認しながら開発を進めます。",
  },
  {
    number: "04",
    title: "小さく公開・導入",
    body: "必要な範囲から公開し、現場で使い始めます。",
  },
  {
    number: "05",
    title: "改善・拡張",
    body: "フィードバックをもとに改善・拡張します。",
  },
  {
    number: "06",
    title: "運用サポート",
    body: "安心して使い続けられるよう支援します。",
  },
];

const cases = [
  {
    title: "製造業｜受注・工程管理システム",
    category: "業務・データ・管理画面",
    summary: "紙とExcelでの管理を一元化し、進捗の見える化と二重入力を削減。",
    tags: ["業務", "データ", "管理画面"],
    tone: "teal",
  },
  {
    title: "サービス業｜予約・顧客管理",
    category: "予約・顧客情報・請求",
    summary: "予約・顧客情報・請求を一元化。スタッフの負担を大幅に削減。",
    tags: ["業務", "Web", "データ活用"],
    tone: "teal",
  },
  {
    title: "コーポレートサイト機能強化",
    category: "CMS・検索・フォーム",
    summary:
      "CMS・検索・フォーム・AIチャットを導入し、問い合わせ対応と更新を効率化。",
    tags: ["Web", "CMS", "AIチャット"],
    tone: "gold",
  },
  {
    title: "卸売業｜データ連携・自動化",
    category: "基幹・販売・在庫連携",
    summary: "基幹・販売・在庫をつなぎ、集計と発注業務を自動化。",
    tags: ["データ", "自動化", "運用改善"],
    tone: "olive",
  },
];
---

<BaseLayout
  title={home.title}
  description={home.description}
  bodyClass="home-page"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1 class="hero-title-lines">
          <span>業務を動かす<wbr />仕組みを、</span>
          <span>現場に合わせて<wbr />設計する。</span>
        </h1>
        <p class="hero-lead">
          <span>業務システム、Webアプリ、管理画面、データ連携、</span>
          <span>サイト機能も必要な範囲から。</span>
          <span>要件整理から開発・運用改善まで、一気通貫で伴走します。</span>
        </p>
        <div class="actions">
          <a class="btn primary" href="/contact/">{home.primaryCta} →</a>
          <a class="btn outline" href="/pricing/">{home.secondaryCta}</a>
        </div>
      </div>

      <div class="hero-route" aria-label="支援範囲のルートマップ">
        <picture>
          <source
            media="(max-width: 760px)"
            srcset="/assets/systems-hero-route-map.png"
          />
          <img
            class="hero-route-map"
            srcset="/assets/systems-hero-route-map-concept.png 863w, /assets/systems-hero-route-map-concept-2x.png 1726w"
            sizes="100vw"
            src="/assets/systems-hero-route-map-concept.png"
            alt=""
            aria-hidden="true"
          />
        </picture>
        <ol class="route-stations">
          {
            routeSteps.map((step, index) => (
              <li class={index === 4 ? "station station-active" : "station"}>
                <span class="station-number">{step.number}</span>
                <strong>{step.title}</strong>
                <small>{step.body}</small>
              </li>
            ))
          }
        </ol>
        <div class="route-lanes" aria-hidden="true">
          <span class="lane gold">業務レーン</span>
          <span class="lane teal">データレーン</span>
          <span class="lane blue">Webレーン</span>
          <span class="lane gray">運用レーン</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section route-section">
    <div class="container split-head">
      <div class="section-head">
        <h2>サービスの全体像</h2>
        <p>4つのルートで、課題から成果までをつなぎます。</p>
      </div>
      <a class="text-link" href="/services/">サービス一覧を見る</a>
    </div>
    <div class="container">
      <div class="route-table" aria-label="支援ルート表">
        {
          lanes.map((lane) => (
            <article class={`route-row tone-${lane.tone}`}>
              <div class="route-label">
                <img src={lane.icon} alt="" aria-hidden="true" loading="lazy" />
                <div>
                  <strong>{lane.name}</strong>
                  <span>{lane.description}</span>
                </div>
              </div>
              <div class="route-cells">
                {lane.cells.map((cell) => (
                  <span>{cell}</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section white">
    <div class="container planner-grid" data-planner>
      <div>
        <div class="section-head">
          <h2>今の課題から、最適なルートを見つける</h2>
          <p>当てはまる課題を選ぶだけで、おすすめの進め方を提案します。</p>
        </div>
        <form class="planner-options">
          <div class="planner-tabs" aria-hidden="true">
            {
              plannerTabs.map((tab, index) => (
                <span class={index === 0 ? "active" : undefined}>{tab}</span>
              ))
            }
          </div>
          <div class="planner-checkgrid">
            {
              plannerOptions.map((option, index) => (
                <label>
                  <input
                    type="checkbox"
                    data-area={option.area}
                    checked={[4, 5].includes(index)}
                  />
                  <span>{option.label}</span>
                </label>
              ))
            }
          </div>
          <button class="quiet-button" type="button" data-reset-planner
            >選択をクリア</button
          >
        </form>
      </div>

      <aside class="planner-output" aria-live="polite">
        <p class="output-kicker">おすすめのルート（例）</p>
        <ol class="route-brief-list">
          {
            routeSteps.map((step, index) => (
              <li class={index === 4 ? "active" : undefined}>
                <span>{step.number}</span>
                <div>
                  <strong>{step.title}</strong>
                  <small>{step.body}</small>
                </div>
              </li>
            ))
          }
        </ol>
        <p class="route-summary">
          <strong data-output-title>Web・サイト機能 + 運用改善</strong>
          <span><span data-selected-count>2</span>件の課題から提案</span>
        </p>
        <a class="btn primary wide" href="/contact/" data-consult-link
          >この内容で相談する →</a
        >
      </aside>
    </div>
  </section>

  <section class="section white">
    <div class="container before-after">
      <div class="section-head section-head-side">
        <h2>
          <span>仕組みが変わると、</span>
          <span>現場が変わる。</span>
        </h2>
        <p>散らばっていた業務が、つながり、回り出します。</p>
        <a class="text-link" href="/guide/">詳しく見る</a>
      </div>
      <div class="flow-change">
        <article>
          <h3>Before</h3>
          <ul>
            <li>紙・Excel・メールで情報が分散</li>
            <li>申請や承認の状況が見えない</li>
            <li>データの集計と確認に時間がかかる</li>
            <li>サイト更新や問い合わせ対応が属人化</li>
          </ul>
        </article>
        <img
          class="flow-arrow"
          src="/assets/flow-arrow.png"
          alt=""
          aria-hidden="true"
          loading="lazy"
        />
        <div class="flow-bridge" aria-label="業務データが整理される流れ">
          <div class="flow-source">
            <span>申請</span>
            <span>問い合わせ</span>
            <span>更新依頼</span>
          </div>
          <div class="flow-hub">
            <strong>整理</strong>
            <small>ルール化・集約</small>
          </div>
          <div class="flow-screen">
            <strong>管理画面</strong>
            <small>検索・確認・更新</small>
          </div>
        </div>
        <article class="after">
          <h3>After</h3>
          <ul>
            <li>業務フローが明確で、申請がスムーズ</li>
            <li>データがつながり、状況をすぐ確認できる</li>
            <li>管理画面やCMSで必要な情報を更新できる</li>
            <li>公開後も改善サイクルを回せる</li>
          </ul>
        </article>
        <img
          class="workflow-illustration"
          src="/assets/systems-workflow-illustration.png"
          alt="業務データが管理画面へ集約されるイメージ"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-head">
      <div class="section-head">
        <h2>料金の目安</h2>
        <p>目的と規模に合わせて組み立てる、シンプルなプラン構成です。</p>
      </div>
      <a class="text-link" href="/pricing/">料金の詳細を見る</a>
    </div>
    <div class="container">
      <div class="compact-table pricing-table" aria-label="料金の目安">
        <div class="pricing-head" aria-hidden="true">
          <strong>プランの目安</strong>
          <strong>内容</strong>
          <strong>期間の目安</strong>
          <strong>費用の目安</strong>
        </div>
        {
          pricingRows.map((item, index) => (
            <article>
              <strong>{item.label}</strong>
              <p>{item.note}</p>
              <small>{item.period}</small>
              <span>{item.price}</span>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section white">
    <div class="container">
      <div class="section-head">
        <h2>開発の進め方</h2>
        <p>段階的に進めるから、リスクを抑えて成果につながります。</p>
      </div>
      <ol class="process-line">
        {
          developmentSteps.map((step) => (
            <li>
              <span>{step.number}</span>
              <strong>{step.title}</strong>
              <small>{step.body}</small>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container split-head">
      <div class="section-head">
        <h2>導入事例</h2>
        <p>公開できる範囲で、課題と支援ルートが見える形に整理しています。</p>
      </div>
      <a class="text-link" href="/works/">事例をもっと見る</a>
    </div>
    <div class="container case-grid">
      {
        cases.map((item) => (
          <article class={`case-card tone-${item.tone}`}>
            <span>{item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <div class="case-tags" aria-label="支援領域">
              {item.tags.map((tag) => (
                <em>{tag}</em>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section contact-band">
    <div class="container contact-grid">
      <div>
        <h2>まずは、今の課題をお聞かせください。</h2>
        <p>どこから手をつければいいか、一緒に整理します。</p>
        <div class="contact-tags" aria-label="相談しやすい内容">
          <span>オンライン相談OK</span>
          <span>初回相談は無料</span>
          <span>無理な営業はしません</span>
        </div>
      </div>
      <form class="quick-form" action={site.contactFormAction} method="post">
        <input
          type="hidden"
          name="_subject"
          value="Acecore Systems トップページからのお問い合わせ"
        />
        <input type="hidden" name="source" value="systems.acecore.net" />
        <label>
          お名前
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          会社名
          <input name="company" autocomplete="organization" />
        </label>
        <label>
          メールアドレス
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label>
          ご相談内容
          <select name="category" required>
            <option value="">選択してください</option>
            <option>業務システム開発について</option>
            <option>Webアプリ・管理画面について</option>
            <option>サイト機能追加について</option>
            <option>データ連携・運用改善について</option>
          </select>
        </label>
        <button class="btn primary" type="submit">内容を送信する →</button>
      </form>
      <div class="contact-methods">
        <a href={site.lineUrl}>
          <img src="/assets/contact-icon-line.png" alt="" aria-hidden="true" />
          <span>
            LINEで相談する
            <small>見積に関する相談も受付中</small>
          </span>
        </a>
        <a href={`mailto:${site.email}`}>
          <img src="/assets/contact-icon-mail.png" alt="" aria-hidden="true" />
          <span>
            メールで相談する
            <small>24時間受付中</small>
          </span>
        </a>
      </div>
    </div>
  </section>

  <script>
    const planner = document.querySelector("[data-planner]");

    if (planner) {
      const checkboxes = Array.from(
        planner.querySelectorAll('input[type="checkbox"][data-area]'),
      );
      const resetButton = planner.querySelector("[data-reset-planner]");
      const count = planner.querySelector("[data-selected-count]");
      const title = planner.querySelector("[data-output-title]");
      const body = planner.querySelector("[data-output-body]");
      const list = planner.querySelector("[data-output-list]");
      const consultLink = planner.querySelector("[data-consult-link]");
      const routeDots = Array.from(
        planner.querySelectorAll(".route-brief-list li"),
      );
      const copy = {
        business: {
          title: "業務フロー + 管理画面",
          body: "現場の申請・承認・確認の流れを整理し、使いやすい管理画面へ落とし込みます。",
          list: "業務整理、権限、申請フロー、一覧・検索、通知",
          active: [1, 2],
        },
        admin: {
          title: "管理画面 + Webアプリ",
          body: "日常運用で使う画面を中心に、入力、検索、CSV、権限、スマートフォン対応を整えます。",
          list: "UI設計、管理画面、会員機能、CSV、ログ",
          active: [3],
        },
        data: {
          title: "データ連携 + 業務システム",
          body: "外部サービスやスプレッドシートをつなぎ、二重入力を減らしてデータを活用できる状態にします。",
          list: "API連携、データ定義、集計、通知、バックアップ",
          active: [1, 4],
        },
        site: {
          title: "Web・サイト機能 + 運用改善",
          body: "CMS、検索、フォーム、AIチャットなどを、問い合わせ対応や情報更新の運用まで含めて設計します。",
          list: "CMS、サイト内検索、フォーム、AIチャット、問い合わせ導線",
          active: [5],
        },
        ops: {
          title: "運用改善 + 継続サポート",
          body: "公開後の安定運用、保守、監視、改善提案まで含めて、長く使える状態を作ります。",
          list: "運用ルール、監視、保守、改善提案、移行計画",
          active: [1, 6],
        },
      };

      const updatePlanner = () => {
        const selected = checkboxes.filter((checkbox) => checkbox.checked);
        const areas = selected
          .map((checkbox) => checkbox.dataset.area)
          .filter(Boolean);
        const uniqueAreas = [...new Set(areas)];
        const priority = ["site", "business", "data", "admin", "ops"];
        const primary =
          priority.find((area) => uniqueAreas.includes(area)) || "site";
        const selectedCopy = copy[primary];
        const activeSet = new Set(
          uniqueAreas.flatMap((area) => copy[area]?.active || []),
        );

        if (count) count.textContent = String(selected.length);
        if (title) title.textContent = selectedCopy.title;
        if (body) body.textContent = selectedCopy.body;
        if (list)
          list.textContent = uniqueAreas
            .map((area) => copy[area]?.list)
            .filter(Boolean)
            .join(" / ");
        if (consultLink) {
          const scope = encodeURIComponent(selectedCopy.title);
          consultLink.setAttribute("href", `/contact/?scope=${scope}`);
        }

        routeDots.forEach((dot, index) => {
          dot.classList.toggle("active", activeSet.has(index + 1));
        });
      };

      checkboxes.forEach((checkbox) =>
        checkbox.addEventListener("change", updatePlanner),
      );
      resetButton?.addEventListener("click", () => {
        checkboxes.forEach((checkbox) => {
          checkbox.checked = false;
        });
        updatePlanner();
      });

      updatePlanner();
    }
  </script>
</BaseLayout>
